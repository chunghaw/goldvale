# ── AWS Aurora PostgreSQL (the one backend; pgvector enabled) ──────────────────
# postgres://USER:PASSWORD@CLUSTER-ENDPOINT:5432/goldvale
DATABASE_URL=

# ── AWS / Bedrock ──────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Set these to the model IDs you ENABLED in the Bedrock console (region-specific).
BEDROCK_CHAT_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
EMBED_DIM=1024

# ── Auth / payments (later iterations) ─────────────────────────────────────────
AUTH_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Goldvale
